# Discord Bot トークン
DISCORD_TOKEN=your_discord_bot_token_here

# Claude Code を実行できるユーザーのDiscord ID（カンマ区切りで複数指定可）
ALLOWED_USERS=123456789012345678

# フォーラムチャンネルID（プロンプト受付用）
FORUM_CHANNEL_ID=000000000000000000

# ログチャンネルID（実行ログ送信用、空または 0 で無効）
LOG_CHANNEL_ID=000000000000000000

# サーバー（ギルド）ID（任意、空または 0 で全ギルド）
GUILD_ID=000000000000000000

# Claude Code の権限チェックをスキップする（デフォルト: false）
# true  → --dangerously-skip-permissions で全操作を自動許可。sensitive path のみ Discord 承認。
# false → 全ツールごとに Discord ボタンで許可/拒否を選択
SKIP_PERMISSIONS=false

# 権限リクエスト用の内部HTTPポート
HOOK_PORT=8585

# Claude Code 実行ファイル名/パス（PATH 上に無い場合はフルパス指定）
CLAUDE_BIN=claude

# 権限モード（SKIP_PERMISSIONS=false 時のみ参照）
# 空 / default / acceptEdits / plan / auto / dontAsk / bypassPermissions
PERMISSION_MODE=

# 1ターンの最大エージェント実行回数（空で無制限）
MAX_TURNS=

# 1ターンの最大コスト USD（空で無制限）
MAX_BUDGET_USD=

# ソフト/ハードタイムアウト（秒）
SOFT_TIMEOUT=600
HARD_TIMEOUT=3600

# スレッド単位の並列実行上限
MAX_CONCURRENT_RUNS=5
