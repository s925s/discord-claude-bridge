# Discord Bot トークン
DISCORD_TOKEN=your_discord_bot_token_here

# Claude Code を実行できるユーザーのDiscord ID（カンマ区切りで複数指定可）
ALLOWED_USERS=123456789012345678

# フォーラムチャンネルID（プロンプト受付用）
FORUM_CHANNEL_ID=000000000000000000

# ログチャンネルID（実行ログ送信用）
LOG_CHANNEL_ID=000000000000000000

# サーバー（ギルド）ID
GUILD_ID=000000000000000000

# Claude Code の権限チェックをスキップする（デフォルト: false）
# true  → 全操作を自動許可（確認なし）
# false → Discordにボタンが表示され、許可/拒否を選択できる
SKIP_PERMISSIONS=false

# 権限リクエスト用の内部HTTPポート（SKIP_PERMISSIONS=false 時のみ使用）
HOOK_PORT=8585
